# ImmoPro environment variables
# Copy to `.env` and fill in. Never commit the real `.env`.

# --- Supabase (required) ---
PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# SERVER ONLY. Do not prefix with PUBLIC_. Never exposed to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Optional / legacy ---
# External contact-form endpoint (superseded by the /api/leads route).
PUBLIC_API_URL=https://logiciel-formulaire.vercel.app
