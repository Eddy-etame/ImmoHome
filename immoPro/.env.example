# ImmoPro environment variables
# Copy to `.env` and fill in. Never commit the real `.env`.

# --- Supabase (required) ---
PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# SERVER ONLY. Do not prefix with PUBLIC_. Never exposed to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Owner console second factor (optional) ---
# Set a shared passphrase to require it on /atelier IN ADDITION to owner login.
# Leave empty to disable (owner login alone). SERVER ONLY.
ATELIER_PASSPHRASE=

# --- Forms + email microservice (mwcrea Forms) ---
# ImmoHome sends NO email itself and needs NO SMTP. It only POSTs to the
# hosted Forms app, which owns SMTP and delivers the emails. Create a form in
# the Forms admin GUI, copy its UUID here. Leave PUBLIC_FORM_ID empty to make
# email best-effort (leads still save to the database).
PUBLIC_FORM_API_URL=https://logiciel-formulaire.vercel.app/api
PUBLIC_FORM_ID=
