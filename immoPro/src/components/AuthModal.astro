---
// Global auth modal + favorites/account wiring.
// Included once in MainLayout. Prospects sign in / sign up to save favorites.
---

<dialog id="auth-modal" class="auth-dialog">
  <div class="p-8 relative">
    <button type="button" id="auth-close" aria-label="Fermer" class="absolute top-3.5 right-4 text-2xl leading-none text-foreground/40 hover:text-foreground cursor-pointer">×</button>

    <div class="text-[11px] uppercase tracking-[0.25em] text-foreground/45 mb-2">ImmoPro</div>
    <h2 id="auth-title" class="serif text-3xl tracking-tight mb-1">Se connecter</h2>
    <p id="auth-sub" class="text-sm text-foreground/60 mb-6">Connectez-vous pour enregistrer vos biens favoris.</p>

    <div id="auth-tabs" class="flex gap-1 mb-5 text-sm">
      <button type="button" id="auth-tab-signin" class="auth-tab is-active">Se connecter</button>
      <button type="button" id="auth-tab-signup" class="auth-tab">Créer un compte</button>
    </div>

    <form id="auth-form" novalidate class="space-y-3">
      <div id="auth-name-wrap" class="hidden">
        <input id="auth-name" type="text" placeholder="Nom complet" autocomplete="name" class="auth-input" />
      </div>
      <input id="auth-email" type="email" required placeholder="Email" autocomplete="email" class="auth-input" />
      <input id="auth-password" type="password" required minlength="6" placeholder="Mot de passe" autocomplete="current-password" class="auth-input" />
      <p id="auth-msg" class="text-xs hidden"></p>
      <button type="submit" id="auth-submit" class="w-full py-3 bg-foreground text-background font-medium rounded-xl text-sm tracking-widest hover:bg-foreground/90 transition-colors cursor-pointer active:scale-[0.99]">
        Se connecter
      </button>
    </form>

    <!-- Post-signup: confirmation email sent. Shown instead of the form. -->
    <div id="auth-sent" class="hidden text-center">
      <div class="mx-auto mb-4 w-12 h-12 rounded-full flex items-center justify-center bg-[#0F766E]/10 text-[#0F766E] text-2xl" aria-hidden="true">✉</div>
      <h3 id="auth-sent-title" class="serif text-2xl tracking-tight mb-2">Vérifiez votre boîte mail</h3>
      <p id="auth-sent-sub" class="text-sm text-foreground/65 mb-1">Nous avons envoyé un lien de confirmation à</p>
      <p id="auth-sent-email" class="text-sm font-medium mb-5 break-all"></p>
      <p id="auth-resend-msg" class="text-xs mb-3 hidden"></p>
      <button type="button" id="auth-resend" class="w-full py-3 border border-border rounded-xl text-sm tracking-widest hover:border-foreground transition-colors cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed">Renvoyer l’email</button>
      <button type="button" id="auth-back" class="mt-3 text-xs text-foreground/55 hover:text-foreground cursor-pointer transition-colors">Retour à la connexion</button>
    </div>
  </div>
</dialog>

<style>
  .auth-dialog { border: 1px solid var(--border); background: var(--background); color: var(--foreground); padding: 0; border-radius: 1.25rem; max-width: 400px; width: calc(100% - 2rem); box-shadow: 0 32px 64px -12px rgb(0 0 0 / 0.32); }
  .auth-dialog::backdrop { background: rgb(0 0 0 / 0.6); backdrop-filter: blur(3px); }
  .auth-dialog[open] { animation: auth-pop .28s cubic-bezier(.22,1,.36,1); }
  @keyframes auth-pop { from { opacity: 0; transform: scale(.96) translateY(8px); } to { opacity: 1; transform: none; } }
  .auth-tab { padding: .4rem .95rem; border-radius: 999px; color: var(--foreground); opacity: .5; cursor: pointer; transition: opacity .2s, background-color .2s; }
  .auth-tab.is-active { opacity: 1; background: color-mix(in oklab, var(--foreground) 8%, transparent); }
  .auth-input { width: 100%; border: 1px solid var(--border); padding: .75rem 1rem; border-radius: .75rem; font-size: .875rem; background: var(--background); color: var(--foreground); transition: border-color .2s; }
  .auth-input:focus { outline: none; border-color: var(--foreground); }
  @media (prefers-reduced-motion: reduce) { .auth-dialog[open] { animation: none; } }
</style>

<script>
  import { supabase } from '../lib/supabase/client';
  import { loadFavorites, isFavorited, toggleFavorite } from '../lib/favorites';

  type Mode = 'signin' | 'signup';
  let mode: Mode = 'signin';
  let pendingUid: string | null = null;

  const $ = (id: string) => document.getElementById(id);
  const dlg = () => $('auth-modal') as HTMLDialogElement | null;
  const isEn = () => (localStorage.getItem('immopro_locale') || 'fr') === 'en';

  const T = {
    signin: () => (isEn() ? 'Sign in' : 'Se connecter'),
    signup: () => (isEn() ? 'Create account' : 'Créer un compte'),
    sub: () => (isEn() ? 'Sign in to save your favorite properties.' : 'Connectez-vous pour enregistrer vos biens favoris.'),
    subUp: () => (isEn() ? 'Create an account to save your favorites.' : 'Créez un compte pour enregistrer vos favoris.'),
    invalid: () => (isEn() ? 'Enter a valid email and a 6+ character password.' : 'Email valide et mot de passe de 6+ caractères requis.'),
    confirm: () => (isEn() ? 'Account created. Check your email to confirm, then sign in.' : 'Compte créé. Confirmez votre email, puis connectez-vous.'),
    signout: () => (isEn() ? 'Sign out' : 'Déconnexion'),
    inboxTitle: () => (isEn() ? 'Check your inbox' : 'Vérifiez votre boîte mail'),
    inboxSub: () => (isEn() ? 'We sent a confirmation link to' : 'Nous avons envoyé un lien de confirmation à'),
    resend: () => (isEn() ? 'Resend email' : 'Renvoyer l’email'),
    resending: () => (isEn() ? 'Sending…' : 'Envoi…'),
    resent: () => (isEn() ? 'Email sent again — check your inbox (and spam).' : 'Email renvoyé — vérifiez votre boîte (et les spams).'),
    back: () => (isEn() ? 'Back to sign in' : 'Retour à la connexion'),
    authError: () => (isEn()
      ? 'That confirmation link is invalid or has expired. Sign in, or create your account again.'
      : 'Ce lien de confirmation est invalide ou a expiré. Connectez-vous, ou recréez votre compte.'),
  };

  // Where Supabase sends the user after they click the email link.
  const redirectTo = () => `${window.location.origin}/auth/callback`;

  const friendlyError = (m: string) => {
    const low = (m || '').toLowerCase();
    if (low.includes('rate limit')) return isEn()
      ? 'Too many emails sent right now. Please wait a minute and try again.'
      : 'Trop d’emails envoyés pour le moment. Patientez une minute puis réessayez.';
    if (low.includes('invalid login')) return isEn()
      ? 'Incorrect email or password.'
      : 'Email ou mot de passe incorrect.';
    if (low.includes('already registered')) return isEn()
      ? 'This email already has an account. Sign in instead.'
      : 'Un compte existe déjà avec cet email. Connectez-vous.';
    return m;
  };

  // ---------- Post-signup "check your inbox" + resend ----------
  let lastSignupEmail = '';
  let resendCooldown = 0;
  let cooldownTimer: number | null = null;

  function resendMsg(text: string, ok = false) {
    const el = $('auth-resend-msg');
    if (!el) return;
    el.textContent = text;
    el.className = `text-xs mb-3 ${ok ? 'text-[#0F766E]' : 'text-destructive'}`; // no 'hidden' → visible
  }

  function stopCooldown() {
    if (cooldownTimer !== null) { clearInterval(cooldownTimer); cooldownTimer = null; }
    resendCooldown = 0;
  }

  function startCooldown(sec: number) {
    const btn = $('auth-resend') as HTMLButtonElement | null;
    resendCooldown = sec;
    const render = () => {
      if (!btn) return;
      if (resendCooldown <= 0) { btn.disabled = false; btn.textContent = T.resend(); }
      else { btn.disabled = true; btn.textContent = `${T.resend()} (${resendCooldown}s)`; }
    };
    render();
    if (cooldownTimer !== null) clearInterval(cooldownTimer);
    cooldownTimer = window.setInterval(() => {
      resendCooldown -= 1;
      if (resendCooldown <= 0) { stopCooldown(); } render();
    }, 1000);
  }

  function showInbox(email: string) {
    lastSignupEmail = email;
    ['auth-title', 'auth-sub', 'auth-tabs', 'auth-form'].forEach((id) => $(id)?.classList.add('hidden'));
    $('auth-sent')?.classList.remove('hidden');
    const t = $('auth-sent-title'); if (t) t.textContent = T.inboxTitle();
    const s = $('auth-sent-sub'); if (s) s.textContent = T.inboxSub();
    const em = $('auth-sent-email'); if (em) em.textContent = email;
    const back = $('auth-back'); if (back) back.textContent = T.back();
    $('auth-resend-msg')?.classList.add('hidden');
    stopCooldown();
    const rb = $('auth-resend') as HTMLButtonElement | null;
    if (rb) { rb.disabled = false; rb.textContent = T.resend(); }
  }

  function showFormState() {
    $('auth-sent')?.classList.add('hidden');
    stopCooldown();
    ['auth-title', 'auth-sub', 'auth-tabs', 'auth-form'].forEach((id) => $(id)?.classList.remove('hidden'));
    setMode('signin');
  }

  async function resendConfirmation() {
    if (resendCooldown > 0 || !lastSignupEmail) return;
    const btn = $('auth-resend') as HTMLButtonElement | null;
    if (btn) { btn.disabled = true; btn.textContent = T.resending(); }
    $('auth-resend-msg')?.classList.add('hidden');
    const { error } = await supabase.auth.resend({
      type: 'signup',
      email: lastSignupEmail,
      options: { emailRedirectTo: redirectTo() },
    });
    if (error) {
      resendMsg(friendlyError(error.message));
      startCooldown(/rate limit/i.test(error.message) ? 60 : 30);
    } else {
      resendMsg(T.resent(), true);
      startCooldown(30);
    }
  }

  function setMode(m: Mode) {
    mode = m;
    $('auth-tab-signin')?.classList.toggle('is-active', m === 'signin');
    $('auth-tab-signup')?.classList.toggle('is-active', m === 'signup');
    $('auth-name-wrap')?.classList.toggle('hidden', m === 'signin');
    const title = $('auth-title'); if (title) title.textContent = m === 'signin' ? T.signin() : T.signup();
    const sub = $('auth-sub'); if (sub) sub.textContent = m === 'signin' ? T.sub() : T.subUp();
    const submit = $('auth-submit'); if (submit) submit.textContent = m === 'signin' ? T.signin() : T.signup();
    const pw = $('auth-password') as HTMLInputElement | null;
    if (pw) pw.setAttribute('autocomplete', m === 'signin' ? 'current-password' : 'new-password');
    $('auth-msg')?.classList.add('hidden');
  }

  function msg(text: string, ok = false) {
    const el = $('auth-msg');
    if (!el) return;
    el.textContent = text;
    el.className = `text-xs ${ok ? 'text-[#0F766E]' : 'text-destructive'}`;
  }

  (window as any).immoproOpenAuth = (uid?: string) => {
    pendingUid = uid || null;
    showFormState();
    const d = dlg();
    if (d) (d.showModal ? d.showModal() : d.setAttribute('open', ''));
    setTimeout(() => ($('auth-email') as HTMLInputElement | null)?.focus(), 60);
  };

  // ---------- Favorites hearts (present on cards across pages) ----------
  function refreshHearts() {
    document.querySelectorAll('[data-heart]').forEach((btn) => {
      const uid = btn.getAttribute('data-heart');
      if (uid) (btn as HTMLElement).textContent = isFavorited(uid) ? '♥' : '♡';
    });
  }
  function wireHearts() {
    document.querySelectorAll('[data-heart]').forEach((btn) => {
      const el = btn as HTMLElement;
      if (el.dataset.wired === '1') return;
      el.dataset.wired = '1';
      el.addEventListener('click', async (e) => {
        e.preventDefault();
        e.stopPropagation();
        const uid = el.getAttribute('data-heart');
        if (!uid) return;
        const res = await toggleFavorite(uid);
        if (res.needAuth) { (window as any).immoproOpenAuth(uid); return; }
        el.textContent = res.added ? '♥' : '♡';
      });
    });
  }

  // ---------- Account button in the header ----------
  async function updateAccountUI() {
    const links = document.querySelectorAll('[data-account-link]');
    if (!links.length) return;
    const { data } = await supabase.auth.getUser();
    links.forEach((el) => {
      const a = el as HTMLElement;
      if (data.user) {
        a.textContent = T.signout();
        a.onclick = async (e) => { e.preventDefault(); await supabase.auth.signOut({ scope: 'local' }); window.location.reload(); };
      } else {
        a.textContent = T.signin();
        a.onclick = (e) => { e.preventDefault(); (window as any).immoproOpenAuth(); };
      }
    });
  }

  async function refreshAll() {
    await loadFavorites();
    refreshHearts();
    updateAccountUI();
  }

  function setupForm() {
    const form = $('auth-form') as HTMLFormElement | null;
    if (!form || (form as any).dataset.ready === '1') return;
    (form as any).dataset.ready = '1';

    $('auth-tab-signin')?.addEventListener('click', () => setMode('signin'));
    $('auth-tab-signup')?.addEventListener('click', () => setMode('signup'));
    $('auth-close')?.addEventListener('click', () => dlg()?.close());
    $('auth-resend')?.addEventListener('click', resendConfirmation);
    $('auth-back')?.addEventListener('click', showFormState);

    let submitting = false;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (submitting) return; // guard against double-fire (extra signup emails)
      const email = ($('auth-email') as HTMLInputElement).value.trim();
      const password = ($('auth-password') as HTMLInputElement).value;
      const name = ($('auth-name') as HTMLInputElement | null)?.value.trim() || '';
      if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email) || password.length < 6) { msg(T.invalid()); return; }

      submitting = true;
      const submitBtn = $('auth-submit') as HTMLButtonElement | null;
      if (submitBtn) submitBtn.disabled = true;
      try {
        if (mode === 'signup') {
          const { data, error } = await supabase.auth.signUp({
            email,
            password,
            options: { data: { full_name: name, role: 'client' }, emailRedirectTo: redirectTo() },
          });
          if (error) { msg(friendlyError(error.message)); return; }
          // Email confirmation ON → no session yet. Show the "check your inbox"
          // state with a resend option instead of a one-line message.
          if (!data.session) { showInbox(email); return; }
        } else {
          const { error } = await supabase.auth.signInWithPassword({ email, password });
          if (error) { msg(friendlyError(error.message)); return; }
        }

        dlg()?.close();
        form.reset();
        window.dispatchEvent(new CustomEvent('immopro:auth-changed', { detail: { pendingUid } }));
        pendingUid = null;
      } finally {
        submitting = false;
        if (submitBtn) submitBtn.disabled = false;
      }
    });
  }

  window.addEventListener('immopro:auth-changed', async (e: Event) => {
    await refreshAll();
    const uid = (e as CustomEvent).detail?.pendingUid as string | undefined;
    if (uid) {
      const res = await toggleFavorite(uid);
      if (!res.needAuth) {
        const btn = document.querySelector(`[data-heart="${uid}"]`) as HTMLElement | null;
        if (btn) btn.textContent = res.added ? '♥' : '♡';
      }
    }
  });
  window.addEventListener('favorites-updated', refreshHearts);
  window.addEventListener('immopro:locale-changed', updateAccountUI);

  // Keep the account button / favorites in sync when the session changes without
  // a full reload (e.g. email link confirmed in this tab). Deferred with a
  // timeout because calling supabase inside this callback can deadlock the lock.
  supabase.auth.onAuthStateChange((event) => {
    if (event === 'SIGNED_IN' || event === 'SIGNED_OUT' || event === 'USER_UPDATED') {
      setTimeout(() => { refreshAll(); }, 0);
    }
  });

  // If a confirmation link failed (see /auth/callback), the user is bounced back
  // with ?auth=error. Open the modal and explain, then clean the URL.
  function maybeHandleAuthResult() {
    const params = new URLSearchParams(window.location.search);
    if (params.get('auth') === 'error') {
      (window as any).immoproOpenAuth();
      msg(T.authError());
      params.delete('auth');
      const qs = params.toString();
      window.history.replaceState({}, '', window.location.pathname + (qs ? `?${qs}` : ''));
    }
  }

  function init() {
    setupForm();
    wireHearts();
    refreshAll();
    maybeHandleAuthResult();
  }
  init();
  document.addEventListener('astro:page-load', init);
</script>
