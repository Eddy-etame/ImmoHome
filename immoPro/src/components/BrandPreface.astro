---
// Brand Preface — cinematic loader for ImmoPro.
// The script is `is:inline` on purpose: it must run immediately and never be
// coupled to (or blocked by) the app's JS bundle. It self-removes no matter
// what, and there is a CSS backstop that hides it even if JS never runs.
---

<div id="brand-preface" data-preface="true" role="presentation" aria-hidden="true">
  <div class="preface-aura"></div>
  <div class="preface-grain"></div>

  <div class="preface-inner">
    <div class="preface-kicker">Cameroun · Immobilier d’Exception</div>
    <div class="preface-logo" data-word="ImmoPro">ImmoPro</div>
    <div class="preface-rule"><span class="preface-rule-fill"></span></div>
  </div>

  <div class="preface-meta">
    <span class="preface-status">Curation en cours</span>
    <span class="preface-count">0</span>
  </div>
</div>

<script is:inline>
  (function () {
    var KEY = 'immopro_has_seen_preface';
    var p = document.getElementById('brand-preface');
    if (!p) return;

    function clear() {
      var el = document.getElementById('brand-preface');
      if (el && el.parentNode) el.parentNode.removeChild(el);
      document.documentElement.classList.remove('preface-active');
    }

    // Persist a remover across Astro view-transition swaps (document persists).
    document.addEventListener('astro:after-swap', clear);

    // Already shown this session → remove instantly, no animation.
    if (sessionStorage.getItem(KEY) === 'true') { clear(); return; }
    sessionStorage.setItem(KEY, 'true');
    document.documentElement.classList.add('preface-active');

    var reduced = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    var logo = p.querySelector('.preface-logo');
    if (logo && !reduced) {
      var word = logo.getAttribute('data-word') || logo.textContent || '';
      logo.textContent = '';
      for (var i = 0; i < word.length; i++) {
        var sp = document.createElement('span');
        sp.className = 'preface-letter';
        sp.textContent = word[i];
        sp.style.setProperty('--d', (120 + i * 55) + 'ms');
        logo.appendChild(sp);
      }
    }

    var countEl = p.querySelector('.preface-count');
    var fillEl = p.querySelector('.preface-rule-fill');
    var done = false;

    function finish() {
      if (done) return; done = true;
      p.classList.add('is-leaving');
      document.documentElement.classList.remove('preface-active');
      try { window.dispatchEvent(new CustomEvent('immopro:preface-done')); } catch (e) {}
      setTimeout(clear, 1000);
    }

    if (reduced) {
      if (countEl) countEl.textContent = '100';
      if (fillEl) fillEl.style.transform = 'scaleX(1)';
      setTimeout(finish, 300);
    } else {
      var DURATION = 1250;
      var start = (window.performance && performance.now) ? performance.now() : Date.now();
      function tick(now) {
        var t = Math.min(((now || Date.now()) - start) / DURATION, 1);
        var eased = 1 - Math.pow(1 - t, 3);
        if (countEl) countEl.textContent = Math.round(eased * 100);
        if (fillEl) fillEl.style.transform = 'scaleX(' + eased + ')';
        if (t < 1) requestAnimationFrame(tick); else setTimeout(finish, 160);
      }
      requestAnimationFrame(tick);
    }

    // Hard failsafes — the loader must never trap the user.
    setTimeout(finish, 3000);
    window.addEventListener('load', function () { setTimeout(finish, 900); });
  })();
</script>
