---
---

<header class="sticky top-0 z-40 border-b border-border bg-background/85 backdrop-blur">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-5 py-4">
    <a href="/" class="serif text-xl tracking-tight immopro-logo group relative inline-block">
      ImmoPro<span class="text-foreground/40">.</span>
    </a>

    <nav class="hidden items-center gap-7 md:flex">
      <a href="/" class="text-sm text-foreground/70 hover:text-foreground transition-colors ink-link" data-i18n="nav.home">Accueil</a>
      <a href="/properties" class="text-sm text-foreground/70 hover:text-foreground transition-colors ink-link" data-i18n="nav.properties">Biens</a>
      <a href="/favorites" class="text-sm text-foreground/70 hover:text-foreground transition-colors ink-link" data-i18n="nav.favorites">Favoris</a>
      <a href="/about" class="text-sm text-foreground/70 hover:text-foreground transition-colors ink-link" data-i18n="nav.about">À propos</a>
      <a href="/contact" class="text-sm text-foreground/70 hover:text-foreground transition-colors ink-link" data-i18n="nav.contact">Contact</a>
    </nav>

    <div class="flex items-center gap-3">
      <button 
        id="lang-toggle"
        class="text-xs uppercase tracking-widest text-foreground/60 hover:text-foreground cursor-pointer transition-colors"
        aria-label="Switch language">
        EN
      </button>
      <a href="/agent" class="hidden md:block text-sm text-foreground/70 hover:text-foreground">Espace agent</a>
    </div>
  </div>
</header>

<script>
  // Language toggle button (works with MainLayout global system)
  function updateLangButton() {
    const btn = document.getElementById('lang-toggle');
    if (!btn) return;

    const current = localStorage.getItem('immopro_locale') || 'fr';
    btn.textContent = current === 'fr' ? 'EN' : 'FR';

    btn.onclick = () => {
      const next = current === 'fr' ? 'en' : 'fr';
      localStorage.setItem('immopro_locale', next);
      window.dispatchEvent(new CustomEvent('immopro:locale-changed', { detail: { locale: next } }));
      btn.textContent = next === 'fr' ? 'EN' : 'FR';
    };
  }

  updateLangButton();
  document.addEventListener('astro:after-swap', updateLangButton);
  window.addEventListener('immopro:locale-changed', updateLangButton);
</script>