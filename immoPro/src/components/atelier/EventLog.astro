---
// Editorial event log viewer — read-only history of recent maintenance operations
---

<div class="border border-border bg-card p-8 rounded-2xl">
  <div class="flex items-center justify-between mb-4">
    <h3 class="font-medium text-xl" data-i18n="atelier.event_log">Historique des opérations</h3>
    <button id="atelier-log-export" class="text-xs px-3 py-1.5 border border-border rounded-xl cursor-pointer hover:border-foreground transition-colors" data-i18n="atelier.export">Exporter</button>
  </div>
  <div id="atelier-event-log" class="space-y-2"></div>
</div>

<script>
  // Tiny escape helper (defense against any rogue characters in reason field)
  function escapeText(s: string): string {
    return String(s)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function renderEventLog() {
    const el = document.getElementById('atelier-event-log');
    if (!el) return;
    const logs = JSON.parse(localStorage.getItem('_im_log') || '[]');
    const locale = localStorage.getItem('immopro_locale') || 'fr';
    const emptyMsg = locale === 'fr' ? "Aucune entrée." : "No entries.";

    if (logs.length === 0) {
      el.innerHTML = `<div class="text-foreground/60 text-sm" data-i18n="atelier.no_logs">${emptyMsg}</div>`;
      return;
    }

    el.innerHTML = logs.slice(0, 50).map((l: any) => `
      <div class="border-b border-border pb-2 text-xs">
        <div class="font-mono text-foreground/50">${escapeText(l.timestamp || '')}</div>
        <div class="font-medium">${escapeText(l.action || '')} — ${escapeText(l.actor || '')}</div>
        <div class="text-foreground/60 mt-0.5">${escapeText(l.reason || '')}</div>
      </div>
    `).join('');
  }

  function exportLog() {
    const logs = JSON.parse(localStorage.getItem('_im_log') || '[]');
    if (logs.length === 0) {
      alert('Rien à exporter.');
      return;
    }
    const csv = [
      'timestamp,action,actor,reason',
      ...logs.map((l: any) => [
        l.timestamp,
        l.action,
        l.actor,
        `"${String(l.reason || '').replace(/"/g, '""')}"`
      ].join(','))
    ].join('\n');
    const blob = new Blob([csv], { type: 'text/csv' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `event-log-${new Date().toISOString().slice(0, 10)}.csv`;
    a.click();
    URL.revokeObjectURL(url);
  }

  function init() {
    renderEventLog();
    document.getElementById('atelier-log-export')?.addEventListener('click', exportLog);
  }

  (window as any).renderEventLog = renderEventLog;
  init();
  document.addEventListener('astro:page-load', init);
  document.addEventListener('immopro:locale-changed', renderEventLog);
</script>
