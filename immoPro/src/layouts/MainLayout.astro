---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BrandPreface from '../components/BrandPreface.astro';
import { ViewTransitions } from 'astro:transitions';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  lang?: 'fr' | 'en';
  noindex?: boolean;
}

const {
  title = "ImmoPro — Immobilier d’Exception au Cameroun",
  description = "Découvrez notre sélection exclusive de villas, appartements et terrains d'exception à Douala, Yaoundé et Kribi.",
  ogImage = "https://images.unsplash.com/photo-1600585154340-be6161a56a0c?auto=format&fit=crop&w=1200&q=80",
  ogType = "website",
  lang = "fr",
  noindex = false
} = Astro.props;

const canonicalUrl = Astro.url.href;
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow"} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalUrl} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogImage} />

    <!-- Fonts & Icons -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet">
    
    <!-- Hreflang Tags (Self-referencing for SEO multi-lang) -->
    <link rel="alternate" href={canonicalUrl} hreflang="x-default" />
    <link rel="alternate" href={canonicalUrl} hreflang="fr" />
    <link rel="alternate" href={canonicalUrl} hreflang="en" />

    <ViewTransitions />
  </head>

  <!-- Direction-aware page transition helper + Global systems -->
  <script>
    function setupViewTransitions() {
      const html = document.documentElement;
      let previousPath = location.pathname;
      html.setAttribute('data-nav', 'forward');

      document.addEventListener('astro:before-preparation', (event) => {
        const targetUrl = new URL(event.to, location.origin);
        const targetPath = targetUrl.pathname;
        const isBack = targetPath === '/' || targetPath.split('/').length < previousPath.split('/').length;
        html.setAttribute('data-nav', isBack ? 'back' : 'forward');
      });

      document.addEventListener('astro:after-swap', () => {
        previousPath = location.pathname;
        setTimeout(() => html.setAttribute('data-nav', 'forward'), 650);
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', setupViewTransitions);
    } else {
      setupViewTransitions();
    }

    // ImmoPro ships its intended light "Paper & Ink" identity by default — the
    // gallery-grade editorial look. Dark styles remain in the CSS but are not
    // auto-applied from the OS (that path produced flat, low-contrast sections).
    function applyLightMode() {
      document.documentElement.classList.remove('dark');
    }
    applyLightMode();
    document.addEventListener('astro:after-swap', applyLightMode);

    // === Immersive smooth scrolling (Lenis) — momentum, synced to rAF ===
    import Lenis from 'lenis';
    async function setupSmoothScroll() {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      if ((window as any).__lenis) return;
      const lenis = new Lenis({
        lerp: 0.085,
        wheelMultiplier: 1,
        smoothWheel: true,
        // Native inertia on touch feels better than JS smoothing on mobile.
        syncTouch: false,
      });
      (window as any).__lenis = lenis;
      function raf(time: number) { lenis.raf(time); requestAnimationFrame(raf); }
      requestAnimationFrame(raf);
      // Content height changes across view-transition swaps.
      document.addEventListener('astro:after-swap', () => {
        (window as any).__lenis?.scrollTo(0, { immediate: true });
        requestAnimationFrame(() => (window as any).__lenis?.resize());
      });
    }
    setupSmoothScroll();

    // === Full Lively Text Animations (re-triggers on every reload & navigation) ===
    function initLivelyTextAnimations() {
      const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      // Typewriter
      document.querySelectorAll('[data-kinetic="typewriter"]').forEach(el => {
        const htmlEl = el as HTMLElement;
        if (htmlEl.dataset.kineticDone === 'true') return;
        const text = htmlEl.getAttribute('data-kinetic-text') || htmlEl.textContent || '';
        htmlEl.dataset.kineticDone = 'true';
        if (reducedMotion) {
          // Show final state immediately
          htmlEl.textContent = text;
          return;
        }
        htmlEl.textContent = '';
        let i = 0;
        const iv = setInterval(() => {
          if (i < text.length) {
            htmlEl.textContent += text[i];
            i++;
          } else clearInterval(iv);
        }, 42);
      });

      // Split letters
      document.querySelectorAll('[data-kinetic="letters"]').forEach(el => {
        const htmlEl = el as HTMLElement;
        if (htmlEl.dataset.kineticDone === 'true') return;
        const text = htmlEl.getAttribute('data-kinetic-text') || htmlEl.textContent || '';
        htmlEl.dataset.kineticDone = 'true';
        if (reducedMotion) {
          htmlEl.textContent = text;
          return;
        }
        htmlEl.innerHTML = '';
        text.split('').forEach((char, idx) => {
          const span = document.createElement('span');
          span.textContent = char === ' ' ? '\u00A0' : char;
          span.style.display = 'inline-block';
          span.style.opacity = '0';
          span.style.transform = 'translateY(8px)';
          span.style.transition = `all 0.5s cubic-bezier(0.22,1,0.36,1)`;
          span.style.transitionDelay = `${idx * 28}ms`;
          htmlEl.appendChild(span);
          requestAnimationFrame(() => {
            span.style.opacity = '1';
            span.style.transform = 'translateY(0)';
          });
        });
      });
    }

    // === Stat counters ===
    function initStatCounters() {
      const stats = document.querySelectorAll('.stat[data-target]');
      if (!stats.length) return;
      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      const run = (htmlEl: HTMLElement) => {
        if (htmlEl.dataset.counted === 'true') return;
        htmlEl.dataset.counted = 'true';
        const target = parseFloat(htmlEl.dataset.target || '0');
        const suffix = htmlEl.dataset.suffix || '';
        if (reduced) { htmlEl.textContent = target.toLocaleString('fr-FR') + suffix; return; }
        const duration = 1600;
        const start = performance.now();
        function animate(now: number) {
          const progress = Math.min((now - start) / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 4);
          const current = Math.floor(target * eased);
          htmlEl.textContent = current.toLocaleString('fr-FR') + suffix;
          if (progress < 1) requestAnimationFrame(animate);
          else htmlEl.textContent = target.toLocaleString('fr-FR') + suffix;
        }
        requestAnimationFrame(() => animate(performance.now()));
      };

      // Count up only when each figure scrolls into view.
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) { run(e.target as HTMLElement); io.unobserve(e.target); }
        });
      }, { threshold: 0.45 });
      stats.forEach((el) => io.observe(el));
    }

    // === Reveal on scroll ===
    function initReveals() {
      const reveals = document.querySelectorAll('.reveal');
      if (!reveals.length) return;

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1 });

      reveals.forEach(el => observer.observe(el));
    }

    // === i18n System (Single Source of Truth - using lib/i18n.ts) ===
    import { translations } from '../lib/i18n.ts';
    const I18N = translations;

    function applyI18n() {
      const locale = (localStorage.getItem('immopro_locale') || 'fr') as 'fr' | 'en';
      document.documentElement.setAttribute('lang', locale);
      const dict = I18N[locale] || I18N.fr;

      document.querySelectorAll('[data-i18n]').forEach(el => {
        const htmlEl = el as HTMLElement;
        const key = htmlEl.getAttribute('data-i18n') as keyof typeof translations.fr;
        if (dict[key]) {
          if (htmlEl.hasAttribute('data-kinetic')) {
            htmlEl.setAttribute('data-kinetic-text', dict[key]);
          }
          htmlEl.textContent = dict[key];
        }
      });

      // Translatable placeholder attributes (inputs / textareas)
      document.querySelectorAll('[data-i18n-placeholder]').forEach(el => {
        const htmlEl = el as HTMLInputElement | HTMLTextAreaElement;
        const key = htmlEl.getAttribute('data-i18n-placeholder') as keyof typeof translations.fr;
        if (dict[key]) htmlEl.placeholder = dict[key];
      });

      // Translatable aria-label attributes
      document.querySelectorAll('[data-i18n-aria]').forEach(el => {
        const htmlEl = el as HTMLElement;
        const key = htmlEl.getAttribute('data-i18n-aria') as keyof typeof translations.fr;
        if (dict[key]) htmlEl.setAttribute('aria-label', dict[key]);
      });

      // Translatable document title
      const titleKey = document.documentElement.getAttribute('data-i18n-title') as keyof typeof translations.fr | null;
      if (titleKey && dict[titleKey]) {
        document.title = `${dict[titleKey]} • ImmoPro`;
      }
    }

    // === Global functions ===
    import { supabase } from '../lib/supabase/client.ts';

    (window as any).subscribeForAlerts = async function() {
      const locale = localStorage.getItem('immopro_locale') || 'fr';
      const promptMsg = locale === 'fr'
        ? 'Entrez votre email pour recevoir les nouvelles exclusivités :'
        : 'Enter your email to receive new exclusives:';
      const successMsg = locale === 'fr'
        ? 'Merci ! Vous serez averti des nouvelles exclusivités.'
        : 'Thank you! You will be notified of new exclusives.';

      const email = prompt(promptMsg);
      if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email.trim())) return;
      const { error } = await supabase.from('subscribers').insert({ email: email.trim(), locale });
      // 23505 = already subscribed; treat as success for the visitor.
      if (!error || error.code === '23505') alert(successMsg);
    };

    // === Initialization (correctly wired for every load & navigation) ===
    function runEntranceSystems() {
      initLivelyTextAnimations();
      initStatCounters();
      initReveals();
    }

    function initAllSystems() {
      applyI18n();
      // On the very first load the cinematic loader is up. Hold the entrance
      // animations (typewriter, reveals, counters) until the curtain lifts so
      // they actually play on screen instead of behind the loader.
      if (document.documentElement.classList.contains('preface-active')) {
        let ran = false;
        const go = () => { if (ran) return; ran = true; runEntranceSystems(); };
        window.addEventListener('immopro:preface-done', go, { once: true });
        setTimeout(go, 4300); // safety if the loader event never fires
      } else {
        runEntranceSystems();
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initAllSystems);
    } else {
      initAllSystems();
    }

    document.addEventListener('astro:after-swap', () => {
      // Reset kinetic guards on navigation
      document.querySelectorAll('[data-kinetic]').forEach(el => {
        const htmlEl = el as HTMLElement;
        delete htmlEl.dataset.kineticDone;
      });
      initAllSystems();
    });

    // Language toggle support
    document.addEventListener('immopro:locale-changed', () => {
      document.querySelectorAll('[data-kinetic]').forEach(el => {
        const htmlEl = el as HTMLElement;
        delete htmlEl.dataset.kineticDone;
      });
      initAllSystems();
    });
  </script>

  <body class="min-h-screen flex flex-col">
    <!-- JSON-LD Organization Schema for SEO -->
    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "ImmoPro",
        "url": "https://immohome.vercel.app",
        "logo": "https://images.unsplash.com/photo-1600585154340-be6161a56a0c?auto=format&fit=crop&w=800&q=80",
        "description": "Premium real estate in Cameroon. Curated villas, apartments and land.",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Douala",
          "addressCountry": "CM"
        }
      }
    </script>
    <BrandPreface />
    <Header />
    <main transition:name="page-content" class="flex-grow">
      <slot />
    </main>
    <Footer />
  </body>
</html>