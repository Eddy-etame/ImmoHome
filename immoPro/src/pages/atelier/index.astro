---
export const prerender = false;

import MainLayout from '../../layouts/MainLayout.astro';
import { createSupabaseServerClient } from '../../lib/supabase/server.ts';

// Owner-only console. Enforced on the server against the Supabase session.
const supabase = createSupabaseServerClient({ request: Astro.request, cookies: Astro.cookies });
const { data: { user } } = await supabase.auth.getUser();

let isOwner = false;
let isSignedIn = false;
let displayName = '';
if (user) {
  isSignedIn = true;
  const { data: profile } = await supabase
    .from('profiles')
    .select('role, full_name, email')
    .eq('id', user.id)
    .maybeSingle();
  if (profile?.role === 'owner') {
    isOwner = true;
    displayName = profile.full_name || profile.email || user.email || '';
  }
}
---

<MainLayout title="Console propriétaire · ImmoPro" noindex={true}>
  {!isOwner ? (
    <div class="min-h-[72vh] flex items-center justify-center px-5">
      <div class="max-w-md w-full aura-glow">
        <div class="text-[11px] uppercase tracking-[0.25em] text-foreground/45 mb-3">Accès propriétaire</div>
        <h1 class="serif text-4xl md:text-5xl tracking-tight mb-3">Console propriétaire</h1>
        {isSignedIn ? (
          <p class="text-sm text-foreground/65 mb-8">Ce compte n'a pas les droits propriétaire. Connectez-vous avec un compte propriétaire.</p>
        ) : (
          <p class="text-sm text-foreground/65 mb-8">Réservé aux propriétaires ImmoPro. Connectez-vous.</p>
        )}
        <form id="owner-login" novalidate class="space-y-3">
          <input id="owner-email" type="email" required autocomplete="username" placeholder="Email"
                 class="w-full border border-border px-4 py-3 rounded-xl text-sm bg-background focus:outline-none focus:border-foreground transition-colors" />
          <input id="owner-password" type="password" required autocomplete="current-password" placeholder="Mot de passe"
                 class="w-full border border-border px-4 py-3 rounded-xl text-sm bg-background focus:outline-none focus:border-foreground transition-colors" />
          <p id="owner-error" class="text-xs text-destructive hidden">Identifiants incorrects ou accès non autorisé.</p>
          <button type="submit" class="w-full py-3 bg-foreground text-background font-medium rounded-xl text-sm tracking-widest hover:bg-foreground/90 transition-colors cursor-pointer active:scale-[0.99]">
            Se connecter
          </button>
        </form>
      </div>
    </div>
  ) : (
    <div class="max-w-5xl mx-auto px-5 py-10">
      <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-8">
        <div>
          <div class="text-[11px] uppercase tracking-[0.22em] text-[#0F766E]">Propriétaire</div>
          <h1 class="serif text-4xl tracking-tight">Console propriétaire</h1>
          <p class="text-sm text-foreground/60 mt-1">{displayName}</p>
        </div>
        <button id="owner-logout" class="text-xs uppercase tracking-wider text-foreground/55 hover:text-foreground border border-border hover:border-foreground px-3 py-2 rounded-lg cursor-pointer transition-colors">Déconnexion</button>
      </div>

      <!-- Live counts -->
      <div id="owner-stats" class="grid grid-cols-2 md:grid-cols-5 gap-4 mb-10"></div>

      <!-- Exports -->
      <div class="border border-border bg-card/40 rounded-2xl p-6 mb-6">
        <h2 class="serif text-2xl tracking-tight mb-1">Exports</h2>
        <p class="text-sm text-foreground/60 mb-5">Télécharger les données au format CSV.</p>
        <div class="flex flex-wrap gap-3">
          <button data-export="leads" class="px-5 py-2.5 border border-border rounded-xl text-sm tracking-wider hover:border-foreground transition-colors cursor-pointer">Exporter les prospects</button>
          <button data-export="subscribers" class="px-5 py-2.5 border border-border rounded-xl text-sm tracking-wider hover:border-foreground transition-colors cursor-pointer">Exporter les abonnés</button>
          <button data-export="clients" class="px-5 py-2.5 border border-border rounded-xl text-sm tracking-wider hover:border-foreground transition-colors cursor-pointer">Exporter les clients</button>
        </div>
      </div>

      <!-- Danger zone -->
      <div class="border border-destructive/30 bg-destructive/5 rounded-2xl p-6">
        <div class="text-destructive text-[11px] uppercase tracking-[0.22em] mb-2">Zone sensible — actions irréversibles</div>
        <h2 class="serif text-2xl tracking-tight mb-5">Maintenance</h2>
        <div class="space-y-3">
          <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 border-b border-border pb-3">
            <div>
              <div class="font-medium">Vider le catalogue</div>
              <div class="text-sm text-foreground/60">Supprime définitivement tous les biens et leurs photos.</div>
            </div>
            <button data-danger="properties" data-phrase="SUPPRIMER LES BIENS" class="shrink-0 px-5 py-2.5 bg-destructive text-white text-sm rounded-xl cursor-pointer active:scale-[0.98]">Vider</button>
          </div>
          <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3">
            <div>
              <div class="font-medium">Vider le carnet clients</div>
              <div class="text-sm text-foreground/60">Supprime définitivement clients et rendez-vous.</div>
            </div>
            <button data-danger="clients" data-phrase="SUPPRIMER LES CLIENTS" class="shrink-0 px-5 py-2.5 bg-destructive text-white text-sm rounded-xl cursor-pointer active:scale-[0.98]">Vider</button>
          </div>
        </div>
      </div>
      <div id="owner-msg" class="hidden mt-4 p-4 rounded-xl text-sm"></div>
    </div>
  )}

  <!-- Typed-confirmation dialog -->
  <dialog id="dlg-danger" class="owner-dialog">
    <form id="form-danger" method="dialog" class="p-8">
      <div class="text-destructive text-[11px] uppercase tracking-[0.22em] mb-2">Action irréversible</div>
      <h3 id="dlg-danger-title" class="serif text-2xl tracking-tight mb-4">Confirmer</h3>
      <p class="text-sm text-foreground/70 mb-4">Pour confirmer, tapez exactement : <span id="dlg-danger-phrase" class="font-mono font-medium"></span></p>
      <input id="dlg-danger-input" type="text" autocomplete="off" class="w-full border border-border px-4 py-3 rounded-xl text-sm bg-background font-mono focus:outline-none focus:border-destructive mb-3" />
      <label class="flex items-start gap-2 mb-6 cursor-pointer">
        <input id="dlg-danger-check" type="checkbox" class="mt-1 cursor-pointer" />
        <span class="text-xs text-foreground/70">Je comprends que cette action est définitive.</span>
      </label>
      <div class="flex gap-3">
        <button type="button" id="dlg-danger-cancel" class="flex-1 py-3 border border-border rounded-xl text-sm tracking-wider hover:border-foreground transition-colors cursor-pointer">Annuler</button>
        <button type="submit" id="dlg-danger-go" class="flex-1 py-3 bg-destructive text-white rounded-xl text-sm tracking-wider cursor-pointer disabled:opacity-40" disabled>Exécuter</button>
      </div>
    </form>
  </dialog>

  <style>
    .owner-dialog { border: 1px solid var(--border); background: var(--background); color: var(--foreground); padding: 0; border-radius: 1.25rem; max-width: 480px; width: calc(100% - 2rem); box-shadow: 0 32px 64px -12px rgb(0 0 0 / 0.3); }
    .owner-dialog::backdrop { background: rgb(0 0 0 / 0.65); backdrop-filter: blur(3px); }
  </style>

  <script>
    import { supabase } from '../../lib/supabase/client.ts';

    // ---- Owner login (shown when not an owner) ----
    const loginForm = document.getElementById('owner-login') as HTMLFormElement | null;
    if (loginForm) {
      loginForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        const email = (document.getElementById('owner-email') as HTMLInputElement).value.trim();
        const password = (document.getElementById('owner-password') as HTMLInputElement).value;
        const err = document.getElementById('owner-error');
        err?.classList.add('hidden');
        const { error } = await supabase.auth.signInWithPassword({ email, password });
        if (error) { err?.classList.remove('hidden'); return; }
        window.location.reload();
      });
    }

    // ---- Console (shown to owners) ----
    const statsEl = document.getElementById('owner-stats');
    if (statsEl) bootConsole();

    function toCsv(rows: any[]): string {
      if (!rows.length) return '';
      const cols = Object.keys(rows[0]);
      const esc = (v: any) => `"${String(v ?? '').replace(/"/g, '""')}"`;
      return [cols.join(','), ...rows.map((r) => cols.map((c) => esc(r[c])).join(','))].join('\n');
    }
    function download(name: string, content: string) {
      const blob = new Blob([content], { type: 'text/csv;charset=utf-8' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url; a.download = name; a.click();
      URL.revokeObjectURL(url);
    }
    function showMsg(text: string, ok = true) {
      const el = document.getElementById('owner-msg');
      if (!el) return;
      el.className = `mt-4 p-4 rounded-xl text-sm ${ok ? 'bg-[#0F766E]/10 border border-[#0F766E]/30 text-[#0F766E]' : 'bg-destructive/10 border border-destructive/30 text-destructive'}`;
      el.textContent = text;
      el.classList.remove('hidden');
      setTimeout(() => el.classList.add('hidden'), 6000);
    }

    async function renderStats() {
      const count = async (t: string) => (await supabase.from(t).select('*', { count: 'exact', head: true })).count ?? 0;
      const [props, clients, appts, leads, subs] = await Promise.all([
        count('properties'), count('clients'), count('appointments'), count('leads'), count('subscribers')
      ]);
      const card = (n: number, label: string) =>
        `<div class="border border-border bg-card/40 rounded-2xl p-4"><div class="serif text-3xl text-[#0F766E]">${n}</div><div class="text-[10px] uppercase tracking-wider text-foreground/55 mt-1">${label}</div></div>`;
      if (statsEl) statsEl.innerHTML = card(props, 'Biens') + card(clients, 'Clients') + card(appts, 'Rendez-vous') + card(leads, 'Prospects') + card(subs, 'Abonnés');
    }

    function setupExports() {
      document.querySelectorAll('[data-export]').forEach((btn) => btn.addEventListener('click', async () => {
        const table = (btn as HTMLElement).dataset.export!;
        const { data, error } = await supabase.from(table).select('*');
        if (error) { showMsg('Erreur export : ' + error.message, false); return; }
        if (!data || !data.length) { showMsg('Aucune donnée à exporter.', false); return; }
        download(`${table}-${new Date().toISOString().slice(0, 10)}.csv`, toCsv(data));
      }));
    }

    function setupDanger() {
      const dlg = document.getElementById('dlg-danger') as HTMLDialogElement | null;
      const input = document.getElementById('dlg-danger-input') as HTMLInputElement | null;
      const check = document.getElementById('dlg-danger-check') as HTMLInputElement | null;
      const go = document.getElementById('dlg-danger-go') as HTMLButtonElement | null;
      const cancel = document.getElementById('dlg-danger-cancel');
      const phraseEl = document.getElementById('dlg-danger-phrase');
      const titleEl = document.getElementById('dlg-danger-title');
      if (!dlg || !input || !check || !go) return;

      let target = '';
      let phrase = '';
      const refresh = () => { go.disabled = !(input.value.trim() === phrase && check.checked); };
      input.addEventListener('input', refresh);
      check.addEventListener('change', refresh);
      cancel?.addEventListener('click', () => dlg.close());

      document.querySelectorAll('[data-danger]').forEach((btn) => btn.addEventListener('click', () => {
        target = (btn as HTMLElement).dataset.danger!;
        phrase = (btn as HTMLElement).dataset.phrase!;
        if (phraseEl) phraseEl.textContent = phrase;
        if (titleEl) titleEl.textContent = target === 'properties' ? 'Vider le catalogue' : 'Vider le carnet clients';
        input.value = ''; check.checked = false; go.disabled = true;
        (dlg.showModal ? dlg.showModal() : dlg.setAttribute('open', ''));
      }));

      (document.getElementById('form-danger') as HTMLFormElement)?.addEventListener('submit', async (e) => {
        e.preventDefault();
        if (input.value.trim() !== phrase || !check.checked) return;
        const IMPOSSIBLE = '00000000-0000-0000-0000-000000000000';
        let error = null;
        if (target === 'properties') {
          ({ error } = await supabase.from('properties').delete().neq('id', IMPOSSIBLE));
        } else {
          await supabase.from('appointments').delete().neq('id', IMPOSSIBLE);
          ({ error } = await supabase.from('clients').delete().neq('id', IMPOSSIBLE));
        }
        dlg.close();
        if (error) { showMsg('Erreur : ' + error.message, false); return; }
        showMsg('Opération exécutée.', true);
        renderStats();
      });
    }

    async function bootConsole() {
      document.getElementById('owner-logout')?.addEventListener('click', async () => { await supabase.auth.signOut(); window.location.reload(); });
      setupExports();
      setupDanger();
      await renderStats();
    }
  </script>
</MainLayout>
