---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Favoris • ImmoPro">
  <div class="max-w-6xl mx-auto px-5 py-10">
    <h1 class="serif text-4xl tracking-tight mb-8" data-i18n="nav.favorites">Mes favoris</h1>
    <div id="fav-grid" class="grid md:grid-cols-3 gap-8"></div>
  </div>

  <script>
    import { getFavorites, removeFavorite } from '../lib/favorites.ts';
    import { t } from '../lib/i18n.ts';

    function safe(s: any): string {
      if (s === undefined || s === null) return '';
      return String(s).replace(/[<>&"']/g, (c) => (({ '<': '&lt;', '>': '&gt;', '&': '&amp;', '"': '&quot;', "'": '&#39;' } as any)[c] || c));
    }

    function renderFavorites() {
      const container = document.getElementById('fav-grid');
      if (!container) return;
      const favs = getFavorites();

      if (favs.length === 0) {
        container.innerHTML = `<p class="text-foreground/60" data-i18n="favorites.empty">${t('favorites.empty')}</p>`;
        return;
      }

      container.innerHTML = favs.map(p => `
        <div class="border border-border rounded-2xl overflow-hidden elevate">
          <img src="${safe(p.image)}" alt="${safe(p.title)}" loading="lazy" class="w-full aspect-video object-cover" />
          <div class="p-5">
            <h3 class="serif text-xl">${safe(p.title)}</h3>
            <p class="text-sm text-foreground/60 mt-1">${safe(p.city)} · ${safe(p.surface)} m²</p>
            <div class="mt-4 flex justify-between items-center">
              <a href="/properties/${safe(p.id)}" class="text-sm text-[#0F766E] ink-link">${t('property.breadcrumb_home') === 'Home' ? 'View' : 'Voir'}</a>
              <button data-remove-fav="${safe(p.id)}" class="text-xs text-destructive hover:underline cursor-pointer">${t('property.breadcrumb_home') === 'Home' ? 'Remove' : 'Retirer'}</button>
            </div>
          </div>
        </div>
      `).join('');

      // Attach click listeners to all Retirer buttons
      container.querySelectorAll('[data-remove-fav]').forEach(btn => {
        const id = btn.getAttribute('data-remove-fav');
        btn.addEventListener('click', (e) => {
          e.preventDefault();
          if (id) {
            removeFavorite(id);
            renderFavorites();
          }
        });
      });
    }

    // Support soft-navigation from ViewTransitions
    document.addEventListener('astro:page-load', renderFavorites);
    renderFavorites();
  </script>
</MainLayout>