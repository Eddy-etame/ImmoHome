---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Biens • ImmoPro">
  <div class="mx-auto max-w-6xl px-5 py-10">
    <h1 data-kinetic="letters" data-i18n="properties.title" class="serif text-5xl tracking-tight mb-8">Nos biens d’exception</h1>

    <div class="flex flex-wrap gap-3 mb-8">
      <input id="search" type="text" placeholder="Rechercher..." data-i18n-placeholder="properties.search_placeholder" class="flex-1 min-w-[220px] border border-border px-4 py-2 rounded-xl text-sm" />
      <select id="price-filter" class="border border-border px-4 py-2 rounded-xl text-sm">
        <option value="all" data-i18n="properties.filter.all">Tous les prix</option>
        <option value="100" data-i18n="properties.filter.under_100m">Moins de 100M</option>
        <option value="300" data-i18n="properties.filter.100_300m">100M - 300M</option>
        <option value="high" data-i18n="properties.filter.over_300m">Plus de 300M</option>
      </select>
    </div>

    <div id="grid" class="grid md:grid-cols-3 gap-8">
      <!-- Populated by script -->
    </div>
  </div>

  <script>
    import { getProperties, type Property } from '../lib/data.ts';
    import { toggleFavorite, isFavorited } from '../lib/favorites.ts';

    let properties: Property[] = [];

    function render(filtered: Property[]) {
      const grid = document.getElementById('grid');
      if (!grid) return;
      grid.innerHTML = filtered.map((p: Property) => `
        <div class="property-card group border border-border rounded-2xl overflow-hidden" data-id="${p.id}">
          <div class="relative">
            <img src="${p.image}" class="w-full aspect-[16/10] object-cover" />
            <button data-heart="${p.id}" class="heart absolute top-4 right-4 text-2xl text-white/90 cursor-pointer transition-transform hover:scale-110 active:scale-95">${isFavorited(p.id) ? '♥' : '♡'}</button>
          </div>
          <a href="/properties/${p.id}" class="block p-5">
            <h3 class="serif text-xl">${p.title}</h3>
            <p class="text-sm text-foreground/60 mt-1">${p.city} · ${p.surface} m²</p>
            <div class="mt-4 font-medium">${new Intl.NumberFormat('fr-FR').format(p.price)} FCFA</div>
          </a>
        </div>
      `).join('');

      // Attach heart listeners
      grid.querySelectorAll('[data-heart]').forEach(btn => {
        const id = btn.getAttribute('data-heart');
        btn.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          const prop = properties.find((x: Property) => x.id === id);
          if (prop) {
            toggleFavorite(prop);
            filter();
          }
        });
      });
    }

    function filter() {
      const searchEl = document.getElementById('search') as HTMLInputElement;
      const filterEl = document.getElementById('price-filter') as HTMLSelectElement;
      if (!searchEl || !filterEl) return;

      const term = (searchEl.value || '').toLowerCase();
      const priceMode = filterEl.value;

      const filtered = properties.filter((p: Property) => {
        const matchesTerm = p.title.toLowerCase().includes(term) || p.city.toLowerCase().includes(term);
        let matchesPrice = true;
        if (priceMode === '100') matchesPrice = p.price < 100000000;
        if (priceMode === '300') matchesPrice = p.price >= 100000000 && p.price <= 300000000;
        if (priceMode === 'high') matchesPrice = p.price > 300000000;
        return matchesTerm && matchesPrice;
      });

      render(filtered);
    }

    function init() {
      properties = getProperties();
      
      const searchEl = document.getElementById('search');
      const filterEl = document.getElementById('price-filter');
      
      searchEl?.addEventListener('input', filter);
      filterEl?.addEventListener('change', filter);

      render(properties);
    }

    document.addEventListener('astro:page-load', init);
    document.addEventListener('immopro:locale-changed', () => {
      // Re-render the grid so any future i18n keys inside cards take effect.
      if (properties.length) filter();
    });
    init();
  </script>
</MainLayout>