---
export const prerender = false;

import MainLayout from '../../layouts/MainLayout.astro';
import { getPropertyBySlug, getPublishedProperties, pickSimilar, type PropertyView } from '../../lib/queries.ts';

const { id } = Astro.params;
const property = id ? await getPropertyBySlug(id) : null;

// Unknown / unpublished property → styled 404.
if (!property) {
  return Astro.redirect('/404');
}

// Similar properties (same city OR type), closest by price, max 3.
const all = await getPublishedProperties();
const similar: PropertyView[] = pickSimilar(property, all, 3);
---

<MainLayout 
  title={`${property.title} • ImmoPro`}
  description={property.description}
  ogImage={property.image}
>
  <!-- SEO JSON-LD RealEstateListing Schema -->
  <script type="application/ld+json" is:inline define:vars={{ property }}>
    {
      "@context": "https://schema.org",
      "@type": "RealEstateListing",
      "name": property.title,
      "description": property.description,
      "datePosted": "2026-05-31",
      "price": property.price,
      "priceCurrency": "XAF",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": property.city,
        "addressCountry": "CM"
      },
      "itemOffered": {
        "@type": "Product",
        "name": property.title,
        "image": property.image
      }
    }
  </script>

  <div class="max-w-6xl mx-auto px-5 py-10">
    <!-- Breadcrumb -->
    <div class="mb-6 text-xs uppercase tracking-wider text-foreground/50">
      <a href="/" class="hover:text-foreground" data-i18n="property.breadcrumb_home">Accueil</a> · 
      <a href="/properties" class="hover:text-foreground" data-i18n="property.breadcrumb_properties">Biens</a> · 
      <span class="text-foreground">{property.id.toUpperCase()}</span>
    </div>

    <!-- Title and Location -->
    <div class="mb-8">
      <h1 data-kinetic="letters" class="serif text-5xl tracking-tight mb-2">{property.title}</h1>
      <p class="text-foreground/60 text-lg flex items-center gap-2">
        <span>📍 {property.city}, <span data-i18n="property.country">Cameroun</span></span> · 
        <span>📐 {property.surface} m²</span>
        {property.rooms && <span> · 🛏️ {property.rooms} <span data-i18n="property.rooms_label">pièces</span></span>}
      </p>
    </div>

    <!-- Main Image Gallery (Bento inspired) -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-10">
      <div class="md:col-span-2 aspect-[4/3] rounded-3xl overflow-hidden bg-card">
        <img src={property.images[0] || property.image} class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" alt="Main View" />
      </div>
      <div class="grid grid-cols-2 md:grid-cols-1 md:col-span-2 gap-4">
        <div class="aspect-[16/10] rounded-3xl overflow-hidden bg-card">
          <img src={property.images[1] || property.image} class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" alt="Interior View" />
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="aspect-square rounded-3xl overflow-hidden bg-card">
            <img src={property.images[2] || property.image} class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" alt="Interior view" />
          </div>
          <div class="aspect-square rounded-3xl overflow-hidden bg-card relative">
            <img src={property.images[3] || property.image || property.images[0]} class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" alt="Detail view" />
            {property.images.length > 4 && (
              <div class="absolute inset-0 bg-black/60 flex items-center justify-center text-white text-lg font-medium pointer-events-none">
                +{property.images.length - 4} photos
              </div>
            )}
          </div>
        </div>
      </div>
    </div>

    <!-- Content Grid -->
    <div class="grid md:grid-cols-3 gap-8">
      <div class="md:col-span-2 space-y-10">
        <!-- Description -->
        <div class="space-y-4">
          <h2 class="serif text-3xl tracking-tight" data-i18n="property.description">Description</h2>
          <p class="desc-fr text-lg text-foreground/80 leading-relaxed">{property.description}</p>
          <p class="desc-en text-lg text-foreground/80 leading-relaxed hidden">{property.descriptionEn}</p>
        </div>

        <!-- Features -->
        <div class="space-y-4">
          <h3 class="serif text-2xl tracking-tight" data-i18n="property.highlights">Points d’excellence</h3>
          <ul class="features-fr grid grid-cols-2 gap-3 text-sm text-foreground/80">
            {property.features.map(f => <li class="flex items-center gap-2"><span>✧</span> {f}</li>)}
          </ul>
          <ul class="features-en grid grid-cols-2 gap-3 text-sm text-foreground/80 hidden">
            {property.featuresEn.map(f => <li class="flex items-center gap-2"><span>✧</span> {f}</li>)}
          </ul>
        </div>

        <!-- Neighborhood -->
        {(property.neighborhood || property.neighborhoodEn) && (
          <div class="border-t border-border pt-10 space-y-4">
            <h2 class="serif text-3xl tracking-tight" data-i18n="property.neighborhood">Le quartier</h2>
            <p class="neighborhood-fr text-lg text-foreground/80 leading-relaxed">{property.neighborhood}</p>
            <p class="neighborhood-en text-lg text-foreground/80 leading-relaxed hidden">{property.neighborhoodEn}</p>
          </div>
        )}
        
        <!-- Film Cinematic Section -->
        <div class="border-t border-border pt-10 space-y-6">
          <h2 class="serif text-3xl tracking-tight" data-i18n="property.watch_cinematic">Regarder le film cinématographique</h2>
          
          <div class="grid sm:grid-cols-2 gap-4">
            <button class="film-choice border border-border hover:border-[#0F766E] p-6 rounded-2xl text-left transition-all hover:bg-card/50 cursor-pointer" data-film="highlight">
              <div class="font-medium text-lg" data-i18n="property.film_highlight_title">Highlight Cinématographique</div>
              <div class="text-sm text-foreground/60 mt-1" data-i18n="property.film_highlight_desc">45s · Mouvement de caméra lent</div>
            </button>
            
            <button class="film-choice border border-border hover:border-[#0F766E] p-6 rounded-2xl text-left transition-all hover:bg-card/50 cursor-pointer" data-film="3d">
              <div class="font-medium text-lg" data-i18n="property.3d_tour">Visite Virtuelle 3D</div>
              <div class="text-sm text-foreground/60 mt-1" data-i18n="property.film_3d_desc">2min · Parcours 3D temps réel</div>
              <div class="mt-2 text-[10px] text-[#67E8F9] inline-block bg-[#67E8F9]/10 px-2 py-0.5 rounded-full font-mono">Remotion + Three</div>
            </button>
          </div>
        </div>
      </div>

      <!-- Booking Card -->
      <div>
        <div class="border border-border bg-card/40 backdrop-blur p-8 rounded-3xl sticky top-8 space-y-6">
          <div>
            <div class="text-xs uppercase tracking-wider text-foreground/50 mb-1" data-i18n="property.price_label">Prix de présentation</div>
            <div class="text-3xl font-medium text-foreground tracking-tight">
              {new Intl.NumberFormat('fr-FR').format(property.price)} <span class="text-sm font-normal text-foreground/60">FCFA</span>
            </div>
          </div>

          <div class="border-t border-border pt-4 text-sm text-foreground/70 space-y-2">
            <div class="flex justify-between">
              <span data-i18n="property.type_label">Type de bien :</span>
              <span class="font-medium">{property.type}</span>
            </div>
            <div class="flex justify-between">
              <span data-i18n="property.surface_label">Surface :</span>
              <span class="font-medium">{property.surface} m²</span>
            </div>
            {property.rooms && (
              <div class="flex justify-between">
                <span data-i18n="property.rooms_field">Pièces :</span>
                <span class="font-medium">{property.rooms}</span>
              </div>
            )}
            {property.bathrooms && (
              <div class="flex justify-between">
                <span data-i18n="property.bathrooms_field">Salles de bain :</span>
                <span class="font-medium">{property.bathrooms}</span>
              </div>
            )}
          </div>

          <button id="book-visit-btn" class="w-full py-4 bg-foreground text-background font-medium rounded-xl text-sm tracking-widest hover:bg-foreground/90 transition-colors cursor-pointer active:scale-[0.985]" data-i18n="property.book_visit">
            Réserver une visite privée
          </button>
        </div>
      </div>
    </div>

    <!-- Similar Properties -->
    {similar.length > 0 && (
      <section class="mt-20 pt-12 border-t border-border">
        <div class="mb-10">
          <h2 class="serif text-3xl tracking-tight" data-i18n="property.similar">Biens similaires</h2>
          <p class="text-sm text-foreground/60 mt-2" data-i18n="property.similar_subtitle">D'autres opportunités pourraient vous intéresser</p>
        </div>
        <div class="grid md:grid-cols-3 gap-8">
          {similar.map((p: PropertyView, idx: number) => (
            <a href={`/properties/${p.id}`} class="group border border-border rounded-2xl overflow-hidden reveal elevate block" style={`--i:${idx + 1}`}>
              <div class="relative aspect-[16/10] overflow-hidden">
                <img src={p.image} alt={p.title} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
              </div>
              <div class="p-5">
                <h3 class="serif text-xl">{p.title}</h3>
                <p class="text-sm text-foreground/60 mt-1">{p.city} · {p.surface} m² {p.rooms ? `· ${p.rooms} ch.` : ''}</p>
                <div class="mt-4 flex justify-between items-baseline">
                  <div class="text-lg font-medium">{new Intl.NumberFormat('fr-FR').format(p.price)} FCFA</div>
                  <div class="text-xs text-foreground/50 group-hover:text-[#0F766E]">Voir →</div>
                </div>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}
  </div>

  <script>
    // Custom i18n Toggler for Dynamic Field Content
    function updateCustomi18n() {
      const locale = localStorage.getItem('immopro_locale') || 'fr';
      if (locale === 'fr') {
        document.querySelectorAll('.desc-fr, .features-fr, .neighborhood-fr').forEach(el => el.classList.remove('hidden'));
        document.querySelectorAll('.desc-en, .features-en, .neighborhood-en').forEach(el => el.classList.add('hidden'));
      } else {
        document.querySelectorAll('.desc-fr, .features-fr, .neighborhood-fr').forEach(el => el.classList.add('hidden'));
        document.querySelectorAll('.desc-en, .features-en, .neighborhood-en').forEach(el => el.classList.remove('hidden'));
      }
    }

    document.addEventListener('immopro:locale-changed', updateCustomi18n);
    document.addEventListener('astro:page-load', () => {
      updateCustomi18n();
      setupFilmButtons();
      setupBookingButton();
    });

    function setupFilmButtons() {
      document.querySelectorAll('[data-film]').forEach(btn => {
        btn.addEventListener('click', () => {
          const type = (btn as HTMLElement).dataset.film;
          const titleKey = type === '3d' ? 'property.film_modal_3d' : 'property.film_modal_default';
          const modal = document.createElement('div');
          modal.className = 'fixed inset-0 z-[999] bg-black/95 flex items-center justify-center p-6 transition-all duration-300';
          modal.innerHTML = `
            <div class="max-w-4xl w-full bg-card border border-border rounded-3xl p-8 text-center animate-in fade-in zoom-in duration-300">
              <div class="text-2xl serif mb-4" data-i18n="${titleKey}">Film</div>
              <div class="text-foreground/70 mb-6" data-i18n="property.film_modal_note">Contenu à afficher ici.</div>
              <div class="aspect-video w-full bg-black/50 border border-border rounded-2xl flex items-center justify-center mb-6 text-foreground/45 font-mono text-sm" data-i18n="property.film_modal_placeholder">
                [Remotion Video Player placeholder]
              </div>
              <button class="px-8 py-3 bg-foreground text-background font-medium rounded-xl text-sm tracking-wider hover:bg-foreground/90 transition-colors cursor-pointer" data-i18n="property.film_modal_close">Fermer</button>
            </div>
          `;
          document.body.appendChild(modal);
          modal.querySelector('button')?.addEventListener('click', () => modal.remove());
          // Re-apply i18n so the freshly injected nodes get translated
          window.dispatchEvent(new CustomEvent('immopro:locale-changed'));
        });
      });
    }

    function setupBookingButton() {
      const btn = document.getElementById('book-visit-btn');
      btn?.addEventListener('click', () => {
        const locale = localStorage.getItem('immopro_locale') || 'fr';
        const msg = locale === 'en'
          ? 'Booking form to be integrated (Phase 5 - Agent area).'
          : 'Formulaire de réservation à intégrer (Phase 5 - Espace Agent).';
        alert(msg);
      });
    }

    updateCustomi18n();
    setupFilmButtons();
    setupBookingButton();
  </script>
</MainLayout>